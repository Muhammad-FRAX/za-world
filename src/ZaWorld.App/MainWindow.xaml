<Window x:Class="ZaWorld.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Za-World"
        Height="360"
        Width="640"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Image x:Name="LogoImage"
                   Width="44"
                   Height="44"
                   Margin="0,0,12,0"
                   RenderOptions.BitmapScalingMode="HighQuality" />
            <TextBlock Grid.Column="1"
                       VerticalAlignment="Center"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Text="Za-World Protective Lock" />
        </Grid>

        <StackPanel Grid.Row="1" Margin="0,14,0,0">
            <TextBlock Text="Unlock Hotkey" />
            <TextBox x:Name="UnlockHotkeyTextBox"
                     Margin="0,4,0,0"
                     Text="Ctrl+Alt+Shift+U" />
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,14,0,0">
            <TextBlock Text="Capture Folder" />
            <TextBox x:Name="CaptureFolderTextBox"
                     Margin="0,4,0,0" />
        </StackPanel>

        <StackPanel Grid.Row="3"
                    Margin="0,16,0,0"
                    Orientation="Horizontal">
            <Button Width="110"
                    Margin="0,0,8,0"
                    Click="Lock_Click"
                    Content="Lock" />
            <Button Width="110"
                    Margin="0,0,8,0"
                    Click="Unlock_Click"
                    Content="Unlock" />
            <Button Width="120"
                    Click="SaveSettings_Click"
                    Content="Save Settings" />
            <TextBlock x:Name="StatusText"
                       Margin="12,6,0,0"
                       VerticalAlignment="Center" />
        </StackPanel>

        <TextBlock Grid.Row="4"
                   Margin="0,12,0,0"
                   Foreground="DimGray"
                   TextWrapping="Wrap"
                   Text="While locked: the window minimizes; the mouse can move (hover) but cannot click; keys do not reach apps. Mouse movement and key presses trigger webcam snapshots (throttled). Unlock only with your saved hotkey (default Ctrl+Alt+Shift+U — hold modifiers, then press U)." />

        <TextBlock Grid.Row="5"
                   Margin="0,10,0,0"
                   Foreground="DimGray"
                   FontSize="11"
                   TextWrapping="Wrap"
                   Text="Tip: allow camera access in Windows privacy settings if snapshots do not appear." />
    </Grid>
</Window>
